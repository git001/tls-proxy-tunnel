vtest "tls-proxy-tunnel: TLS SNI map routes to configured upstream"

# The server has an explicit sni: map entry for www.lirui.tech.
# When tpt receives the ClientHello (SNI = www.lirui.tech) it must look up the
# sni map, find the entry, and route to the mapped upstream — NOT the default.
# The default is "ban" so any routing miss would produce an immediate EOF.
#
# Covers tcp.rs lines 100-110: Some(sni_map) branch with a matching SNI entry.

shell {
    cat > ${tmpdir}/backend.py <<'PYEOF'
import socket, threading, os, sys

def handle(conn):
    buf = b''
    while b'\r\n\r\n' not in buf:
        chunk = conn.recv(4096)
        if not chunk:
            conn.close()
            return
        buf += chunk
    conn.sendall(b'HTTP/1.1 200 Connection Established\r\n\r\n')
    while True:
        data = conn.recv(4096)
        if not data:
            break
        conn.sendall(data)
    conn.close()

srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
srv.bind(('127.0.0.1', 55831))
srv.listen(5)
open(os.environ['READY_FILE'], 'w').close()
while True:
    conn, _ = srv.accept()
    threading.Thread(target=handle, args=(conn,), daemon=True).start()
PYEOF
}

process pbackend "env READY_FILE=${tmpdir}/backend_ready python3 ${tmpdir}/backend.py" -start

shell {
    for i in $(seq 1 50); do
        test -f ${tmpdir}/backend_ready 2>/dev/null && exit 0
        sleep 0.2
    done
    echo "ERROR: backend did not start on 55831 in time" >&2
    exit 1
}

shell {
    cat > ${tmpdir}/tpt.yaml <<'EOF'
version: 1
log: disable
servers:
  sni_map_server:
    listen:
      - "127.0.0.1:55830"
    tls: true
    sni:
      www.lirui.tech: corp_proxy
    default: ban
    via:
      use_sni_as_target: true
      target_port: 8443
      connect_timeout: 5s
upstream:
  corp_proxy: "tcp://127.0.0.1:55831"
EOF
}

process ptpt "env TPT_CONFIG=${tmpdir}/tpt.yaml ${tpt}" -start

shell {
    for i in $(seq 1 50); do
        nc -z 127.0.0.1 55830 2>/dev/null && exit 0
        sleep 0.2
    done
    echo "ERROR: tpt did not listen on 55830 in time" >&2
    exit 1
}

# Send TLS ClientHello with SNI = www.lirui.tech.
# tpt looks up the sni map, finds corp_proxy, issues CONNECT www.lirui.tech:8443,
# backend replies 200, and echoes the ClientHello back.
shell {
    python3 - <<'PYEOF'
import socket, sys

CLIENT_HELLO = bytes([
    0x16,0x03,0x01,0x02,0x00,0x01,0x00,0x01,0xfc,0x03,0x03,0x35,0x7a,0xba,
    0x3d,0x89,0xd2,0x5e,0x7a,0xa2,0xd4,0xe5,0x6d,0xd5,0xa3,0x98,0x41,0xb0,
    0xae,0x41,0xfc,0xe6,0x64,0xfd,0xae,0x0b,0x27,0x6d,0x90,0xa8,0x0a,0xfa,
    0x90,0x20,0x59,0x6f,0x13,0x18,0x4a,0xd1,0x1c,0xc4,0x83,0x8c,0xfc,0x93,
    0xac,0x6b,0x3b,0xac,0x67,0xd0,0x36,0xb0,0xa2,0x1b,0x04,0xf7,0xde,0x02,
    0xfb,0x96,0x1e,0xdc,0x76,0xa8,0x00,0x20,0x2a,0x2a,0x13,0x01,0x13,0x02,
    0x13,0x03,0xc0,0x2b,0xc0,0x2f,0xc0,0x2c,0xc0,0x30,0xcc,0xa9,0xcc,0xa8,
    0xc0,0x13,0xc0,0x14,0x00,0x9c,0x00,0x9d,0x00,0x2f,0x00,0x35,0x01,0x00,
    0x01,0x93,0xea,0xea,0x00,0x00,0x00,0x00,0x00,0x13,0x00,0x11,0x00,0x00,
    0x0e,0x77,0x77,0x77,0x2e,0x6c,0x69,0x72,0x75,0x69,0x2e,0x74,0x65,0x63,
    0x68,0x00,0x17,0x00,0x00,0xff,0x01,0x00,0x01,0x00,0x00,0x0a,0x00,0x0a,
    0x00,0x08,0xba,0xba,0x00,0x1d,0x00,0x17,0x00,0x18,0x00,0x0b,0x00,0x02,
    0x01,0x00,0x00,0x23,0x00,0x00,0x00,0x10,0x00,0x0e,0x00,0x0c,0x02,0x68,
    0x32,0x08,0x68,0x74,0x74,0x70,0x2f,0x31,0x2e,0x31,0x00,0x05,0x00,0x05,
    0x01,0x00,0x00,0x00,0x00,0x00,0x0d,0x00,0x12,0x00,0x10,0x04,0x03,0x08,
    0x04,0x04,0x01,0x05,0x03,0x08,0x05,0x05,0x01,0x08,0x06,0x06,0x01,0x00,
    0x12,0x00,0x00,0x00,0x33,0x00,0x2b,0x00,0x29,0xba,0xba,0x00,0x01,0x00,
    0x00,0x1d,0x00,0x20,0x3b,0x45,0xf9,0xbc,0x6e,0x23,0x86,0x41,0xa5,0xb2,
    0xf5,0x03,0xec,0x67,0x4a,0xd7,0x9a,0x17,0x9f,0x0c,0x38,0x6d,0x36,0xf3,
    0x4e,0x5d,0xa4,0x7d,0x15,0x79,0xa4,0x3f,0x00,0x2d,0x00,0x02,0x01,0x01,
    0x00,0x2b,0x00,0x0b,0x0a,0xba,0xba,0x03,0x04,0x03,0x03,0x03,0x02,0x03,
    0x01,0x00,0x1b,0x00,0x03,0x02,0x00,0x02,0x44,0x69,0x00,0x05,0x00,0x03,
    0x02,0x68,0x32,0xda,0xda,0x00,0x01,0x00,0x00,0x15,0x00,0xc5,
])
CLIENT_HELLO += bytes(517 - len(CLIENT_HELLO))

s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.settimeout(5)
s.connect(('127.0.0.1', 55830))
s.sendall(CLIENT_HELLO)

received = b''
while len(received) < len(CLIENT_HELLO):
    chunk = s.recv(4096)
    if not chunk:
        break
    received += chunk

if len(received) < 10 or received[:4] != CLIENT_HELLO[:4]:
    print(f"FAIL: ClientHello not echoed (got {len(received)} bytes, head={received[:4]!r})",
          file=sys.stderr)
    sys.exit(1)

s.shutdown(socket.SHUT_WR)
s.close()
print("OK: SNI map lookup routed to corp_proxy, tunnel works end-to-end")
PYEOF
}

process ptpt -kill TERM
process ptpt -wait
process pbackend -kill TERM
process pbackend -wait
