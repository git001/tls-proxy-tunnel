version: 1
log: info

servers:
  proxy_server:
    listen:
      - "0.0.0.0:8443"
    tls: true
    sni:
      api.example.org: example-api
      www.example.org: corp_proxy
    default: ban
    maxclients: 100
    via:
      use_sni_as_target: true
      target_port: 443
      connect_timeout: 30s
      headers:
        Proxy-Authorization: "Basic $PROXY_AUTH_TOKEN"

  health_server:
    listen:
      - "127.0.0.1:8080"
    default: health
    maxclients: 10

upstream:
  corp_proxy:  "tcp://proxy.internal:3128"      # IPv4 or IPv6
  example-api: "tcp6://api-v1.example.com:443"  # force IPv6
